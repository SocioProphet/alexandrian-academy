{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "alexandrian-academy://schemas/standing-vector-record.schema.json",
  "title": "StandingVectorRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "header",
    "record_id",
    "actor_ref",
    "scope_ref",
    "scores",
    "score_basis",
    "status",
    "evaluated_at"
  ],
  "properties": {
    "header": {
      "$ref": "universal-header.schema.json"
    },
    "record_id": {
      "type": "string",
      "minLength": 8
    },
    "actor_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor_id",
        "actor_type"
      ],
      "properties": {
        "actor_id": {
          "type": "string",
          "minLength": 3
        },
        "actor_type": {
          "type": "string",
          "enum": [
            "human_user",
            "agent_account",
            "org_representative",
            "project_representative"
          ]
        }
      }
    },
    "scope_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "guild_id"
      ],
      "properties": {
        "guild_id": {
          "type": "string",
          "minLength": 2
        },
        "subguild_id": {
          "type": "string"
        },
        "topic_id": {
          "type": "string"
        },
        "competency_id": {
          "type": "string"
        }
      }
    },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "Corpus",
        "Explain",
        "Apply",
        "Teach",
        "Judge",
        "Conduct",
        "Forensics"
      ],
      "properties": {
        "Corpus": {
          "type": "number",
          "minimum": 0
        },
        "Explain": {
          "type": "number",
          "minimum": 0
        },
        "Apply": {
          "type": "number",
          "minimum": 0
        },
        "Teach": {
          "type": "number",
          "minimum": 0
        },
        "Judge": {
          "type": "number",
          "minimum": 0
        },
        "Conduct": {
          "type": "number",
          "minimum": 0
        },
        "Forensics": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "score_basis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_refs",
        "rubric_refs",
        "minimum_threshold_policy_ref"
      ],
      "properties": {
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "rubric_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "minimum_threshold_policy_ref": {
          "type": "string",
          "minLength": 3
        },
        "evaluation_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    },
    "promotion_readiness": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eligible_roles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 2
          }
        },
        "blocked_dimensions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Corpus",
              "Explain",
              "Apply",
              "Teach",
              "Judge",
              "Conduct",
              "Forensics"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "suspended",
        "expired",
        "superseded"
      ]
    },
    "evaluated_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "superseded_by_record_id": {
      "type": "string"
    }
  }
}
