{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "alexandrian-academy://schemas/assessment-plan.schema.json",
  "title": "AssessmentPlan",
  "type": "object",
  "additionalProperties": false,
  "required": ["header", "lom", "extension"],
  "properties": {
    "header": { "$ref": "universal-header.schema.json" },
    "evidence": { "$ref": "evidence-bundle.schema.json" },

    "lom": { "type": "object", "additionalProperties": true },

    "extension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["jurisdiction_id","pedagogy_id","assessments","accommodations_supported","privacy_constraints","accessibility_constraints"],
      "properties": {
        "jurisdiction_id": { "type": "string" },
        "pedagogy_id": { "type": "string" },

        "assessments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["assessment_id","evidence_type","mastery_rule"],
            "properties": {
              "assessment_id": { "type": "string" },
              "evidence_type": {
                "type": "string",
                "enum": ["artifact_submission","formative_quiz","observation_log","performance_task","discussion_oral","portfolio"]
              },
              "rubric_ref": { "type": "string" },
              "mastery_rule": { "type": "object" },
              "feedback_mode": { "type": "string", "enum": ["narrative","rubric_scored","mixed"] }
            }
          }
        },

        "accommodations_supported": {
          "type": "object",
          "additionalProperties": false,
          "required": ["iep_alignment","section504_alignment","gifted_enrichment_alignment"],
          "properties": {
            "iep_alignment": { "type": "boolean" },
            "section504_alignment": { "type": "boolean" },
            "gifted_enrichment_alignment": { "type": "boolean" }
          }
        },

        "privacy_constraints": {
          "type": "object",
          "additionalProperties": false,
          "required": ["privacy_mode"],
          "properties": {
            "privacy_mode": { "type": "string" },
            "retention_policy_ref": { "type": "string" }
          }
        },

        "accessibility_constraints": {
          "type": "object",
          "additionalProperties": false,
          "required": ["alternative_modalities_allowed"],
          "properties": {
            "caption_required_if_media": { "type": "boolean" },
            "transcript_required_if_media": { "type": "boolean" },
            "alternative_modalities_allowed": { "type": "boolean" }
          }
        }
      }
    }
  }
}
