{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "alexandrian-academy://schemas/changeset.v1",
  "title": "ChangeSet",
  "type": "object",
  "required": ["changeset_id", "created_at", "actor", "operation", "targets", "justification"],
  "properties": {
    "changeset_id": { "type": "string", "minLength": 8 },
    "created_at": { "type": "string", "format": "date-time" },
    "actor": {
      "type": "object",
      "required": ["actor_id", "display_name"],
      "properties": {
        "actor_id": { "type": "string", "minLength": 3 },
        "display_name": { "type": "string", "minLength": 1 },
        "roles": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "operation": {
      "type": "string",
      "enum": [
        "PROMOTE_SANDBOX_TO_CANON",
        "REVISE_CANON",
        "REVOKE_CANON",
        "ROLLBACK"
      ]
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["object_type", "object_id", "from_status", "to_status"],
        "properties": {
          "object_type": { "type": "string" },
          "object_id": { "type": "string", "minLength": 3 },
          "from_status": { "type": "string", "enum": ["sandbox", "canon"] },
          "to_status": { "type": "string", "enum": ["sandbox", "canon"] },
          "object_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        },
        "additionalProperties": false
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 3 }
    },
    "justification": {
      "type": "object",
      "required": ["summary", "rationale"],
      "properties": {
        "summary": { "type": "string", "minLength": 8 },
        "rationale": { "type": "string", "minLength": 8 },
        "jurisdiction_profile_id": { "type": "string", "minLength": 3 },
        "pedagogy_profile_id": { "type": "string", "minLength": 3 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
