{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "alexandrian-academy://schemas/power-grant.schema.json",
  "title": "PowerGrant",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "header",
    "grant_id",
    "subject_ref",
    "power",
    "scope_ref",
    "issuer_ref",
    "basis_refs",
    "term",
    "status"
  ],
  "properties": {
    "header": {
      "$ref": "universal-header.schema.json"
    },
    "grant_id": {
      "type": "string",
      "minLength": 8
    },
    "subject_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor_id",
        "actor_type"
      ],
      "properties": {
        "actor_id": {
          "type": "string",
          "minLength": 3
        },
        "actor_type": {
          "type": "string",
          "enum": [
            "human_user",
            "agent_account",
            "org_representative",
            "project_representative"
          ]
        }
      }
    },
    "power": {
      "type": "string",
      "enum": [
        "review_artifacts",
        "issue_soft_labels",
        "moderate_content",
        "sponsor_entrants",
        "issue_mastery_credentials",
        "issue_service_credentials",
        "hear_appeals",
        "edit_charter",
        "invoke_emergency_powers"
      ]
    },
    "scope_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "guild_id"
      ],
      "properties": {
        "guild_id": {
          "type": "string",
          "minLength": 2
        },
        "subguild_id": {
          "type": "string"
        },
        "topic_id": {
          "type": "string"
        },
        "competency_id": {
          "type": "string"
        }
      }
    },
    "issuer_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issuer_id",
        "issuer_role"
      ],
      "properties": {
        "issuer_id": {
          "type": "string",
          "minLength": 3
        },
        "issuer_role": {
          "type": "string",
          "minLength": 2
        }
      }
    },
    "basis_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "standing_vector_ref",
        "charter_clause_refs",
        "constitutional_floor_ref"
      ],
      "properties": {
        "standing_vector_ref": {
          "type": "string",
          "minLength": 3
        },
        "credential_ref": {
          "type": "string"
        },
        "charter_clause_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "constitutional_floor_ref": {
          "type": "string",
          "minLength": 3
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    },
    "term": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issued_at",
        "expires_at",
        "renewable"
      ],
      "properties": {
        "issued_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "renewable": {
          "type": "boolean"
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "suspended",
        "revoked",
        "expired"
      ]
    },
    "revocation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "revoked_at": {
          "type": "string",
          "format": "date-time"
        },
        "revocation_reason": {
          "type": "string",
          "minLength": 3
        },
        "revoked_by": {
          "type": "string",
          "minLength": 3
        }
      }
    },
    "appeal_ref": {
      "type": "string"
    }
  }
}
