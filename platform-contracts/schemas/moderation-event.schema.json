{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "alexandrian-academy://schemas/moderation-event.schema.json",
  "title": "ModerationEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "header",
    "event_id",
    "review_layer",
    "moderator_ref",
    "target_ref",
    "scope_ref",
    "action",
    "reason_code",
    "basis_refs",
    "status",
    "created_at"
  ],
  "properties": {
    "header": {
      "$ref": "alexandrian-academy://schemas/universal-header.schema.json"
    },
    "event_id": {
      "type": "string",
      "minLength": 8
    },
    "review_layer": {
      "type": "string",
      "const": "M1"
    },
    "moderator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_id", "actor_type"],
      "properties": {
        "actor_id": {"type": "string", "minLength": 3},
        "actor_type": {
          "type": "string",
          "enum": ["human_user", "agent_account"]
        },
        "power_grant_ref": {"type": "string"}
      }
    },
    "target_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_type", "target_id"],
      "properties": {
        "target_type": {
          "type": "string",
          "enum": ["comment", "post", "thread", "artifact", "credential", "agent_action"]
        },
        "target_id": {"type": "string", "minLength": 3}
      }
    },
    "scope_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["guild_id"],
      "properties": {
        "guild_id": {"type": "string", "minLength": 2},
        "subguild_id": {"type": "string"},
        "topic_id": {"type": "string"}
      }
    },
    "action": {
      "type": "string",
      "enum": [
        "label",
        "queue",
        "merge_duplicate",
        "warn",
        "freeze",
        "hide",
        "remove",
        "grant_provisional_quality_label"
      ]
    },
    "reason_code": {
      "type": "string",
      "enum": [
        "evidence_adding",
        "clarifying",
        "synthetic",
        "useful",
        "teachable",
        "forensic",
        "bridge_building",
        "underseen",
        "offtopic",
        "unsourced",
        "redundant",
        "troll",
        "unkind",
        "entropy_adding",
        "scope_breaking",
        "overrated",
        "underrated"
      ]
    },
    "basis_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["charter_clause_refs", "constitutional_floor_ref"],
      "properties": {
        "charter_clause_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 3}
        },
        "constitutional_floor_ref": {"type": "string", "minLength": 3},
        "evidence_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 3}
        },
        "standing_vector_ref": {"type": "string"},
        "evaluation_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 3}
        }
      }
    },
    "consequence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "visibility_change": {
          "type": "string",
          "enum": ["none", "deemphasized", "hidden", "removed", "queued"]
        },
        "temporary": {"type": "boolean"},
        "expires_at": {"type": "string", "format": "date-time"}
      }
    },
    "rationale_text": {
      "type": "string",
      "minLength": 3
    },
    "status": {
      "type": "string",
      "enum": ["active", "superseded", "reversed", "expired"]
    },
    "appeal_ref": {"type": "string"},
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
